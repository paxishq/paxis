{
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/types": "^21.0.1",
    "@types/bun": "^1.3.14",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@typescript/native-preview": "^7.0.0-dev.20260514.1",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7"
  },
  "scripts": {
    "prepare": "husky",
    "typecheck": "tsgo --noEmit",
    "check": "biome check",
    "check:fix": "biome check --write",
    "build": "bun build --compile --target=bun-linux-x64 src/index.ts --outfile=paxis",
    "db:push": "bunx drizzle-kit push",
    "auth:generate": "bun node_modules/.bin/better-auth generate --config src/lib/auth.ts --output src/db/auth-schema.ts --yes",
    "dev": "bun run src/index.ts",
    "db:seed-dev": "bun run scripts/seed-dev.ts"
  },
  "dependencies": {
    "@google/genai": "^2.2.0",
    "@hono/zod-validator": "^0.8.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-auth": "^1.6.11",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "lucide-react": "^1.16.0",
    "openai": "^6.37.0",
    "radix-ui": "^1.4.3",
    "react": "19",
    "react-dom": "19",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  }
}
