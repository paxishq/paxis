[Unit]
Description=Paxis EU Compliance OS
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=paxis
Group=caddy
UMask=0117
WorkingDirectory=/home/paxis/app
EnvironmentFile=/etc/paxis.env
ExecStartPre=-/bin/rm -f /run/paxis/app.sock /run/paxis/mcp.sock
ExecStart=/home/paxis/app/paxis
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=paxis

[Install]
WantedBy=multi-user.target
